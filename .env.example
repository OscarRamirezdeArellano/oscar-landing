# ──────────────────────────────────────────────────────────────────
# oscar-landing — environment variables
# Copy to .env.local for local dev. Set in Vercel project for prod.
# ──────────────────────────────────────────────────────────────────

# Resend — sends `compose` form messages.
# Get a free key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Resend "from" address. For prod use a verified domain (no-reply@iqsit.com).
# For dev with no verified domain, leave as default 'onboarding@resend.dev'.
CONTACT_FROM=oscar.iqsit.com <no-reply@iqsit.com>

# Where to send incoming messages.
CONTACT_TO=oscar@iqsit.com

# Anthropic — powers the `chat` command (visitors talk to Claude with portfolio context).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Anthropic model. Default is haiku for cost-efficiency.
# Options: claude-haiku-4-5-20251001 · claude-sonnet-4-6 · claude-opus-4-7
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
